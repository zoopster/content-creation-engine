# Frontend Environment Variables
# Copy to .env.local and set values for your environment

# Backend API URL
# Dev mode (npm run dev): leave empty — the Vite proxy forwards /api to VITE_BACKEND_URL
# Production build (npm run build): set to the public URL of your API server
VITE_API_URL=

# Dev proxy target — where Vite forwards /api requests during development
# Only used by vite.config.ts, not baked into the build
VITE_BACKEND_URL=http://localhost:8000

# Dev server bind address (default: 0.0.0.0 — accessible externally)
# VITE_HOST=0.0.0.0

# Dev server port (default: 5173)
# VITE_PORT=5173
