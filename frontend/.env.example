# Frontend Environment Variables
# Copy to .env.local and set values for your environment.
# .env.local is gitignored and never committed.

# ── Production build ────────────────────────────────────────────────────────
# Set VITE_API_URL before running `npm run build` if the frontend and API
# are served from different origins (e.g. different ports or domains).
#
# Leave empty when nginx proxies /api to the backend on the same origin.
VITE_API_URL=

# ── Dev / preview server ─────────────────────────────────────────────────────
# Where Vite forwards /api requests during `npm run dev` and `npm run preview`.
# This is NOT baked into the production build — only used by the local server.
VITE_BACKEND_URL=http://localhost:8000

# Dev server bind host (default: 0.0.0.0 — reachable from outside the VPS)
# VITE_HOST=0.0.0.0

# Port for `npm run dev` (default: 5173) and `npm run preview` (default: 4173)
# VITE_PORT=5173
